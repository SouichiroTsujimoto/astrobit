{
  "name": "astrobit",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/integration.js",
  "types": "./dist/integration.d.ts",
  "exports": {
    ".": {
      "import": "./dist/integration.js",
      "types": "./dist/integration.d.ts"
    },
    "./env": {
      "types": "./env.d.ts"
    }
  },
  "files": [
    "dist",
    "env.d.ts"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "astro": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "astro": "^6.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "description": "A thin framework for running MoonBit components as Astro islands",
  "keywords": ["astro", "moonbit", "island", "framework", "astro-integration"],
  "repository": {
    "type": "git",
    "url": "https://github.com/SouichiroTsujimoto/astrobit"
  },
  "license": "MIT"
}
